{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "backlog": {
      "command": [
        "backlog",
        "mcp",
        "start"
      ],
      "enabled": true,
      "type": "local"
    },
    "browser-mcp": {
      "command": [
        "pnpm",
        "dlx",
        "@browsermcp/mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "chrome-devtools": {
      "command": [
        "pnpm",
        "dlx",
        "chrome-devtools-mcp@latest",
        "--executablePath",
        "/run/current-system/sw/bin/chromium"
      ],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "command": [
        "pnpm",
        "dlx",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "filesystem": {
      "command": [
        "pnpm",
        "dlx",
        "@modelcontextprotocol/server-filesystem",
        "/home/xnm"
      ],
      "enabled": false,
      "type": "local"
    },
    "git": {
      "command": [
        "uvx",
        "--python",
        "/run/current-system/sw/bin/python",
        "mcp-server-git"
      ],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": [
        "pnpm",
        "dlx",
        "@playwright/mcp@latest",
        "--browser",
        "chrome",
        "--executable-path",
        "/run/current-system/sw/bin/chromium",
        "--headless"
      ],
      "enabled": false,
      "type": "local"
    },
    "podman": {
      "command": [
        "pnpm",
        "dlx",
        "podman-mcp-server"
      ],
      "enabled": false,
      "type": "local"
    },
    "searxng": {
      "command": [
        "pnpm",
        "dlx",
        "mcp-searxng"
      ],
      "enabled": true,
      "environment": {
        "SEARXNG_URL": "http://127.0.0.1:7777"
      },
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "pnpm",
        "dlx",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": false,
      "type": "local"
    },
    "time": {
      "command": [
        "uvx",
        "--python",
        "/run/current-system/sw/bin/python",
        "mcp-server-time"
      ],
      "enabled": false,
      "type": "local"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "glm-4.7-flash:latest": {
          "_launch": true,
          "name": "glm-4.7-flash:latest"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  },
  "theme": "catppuccin"
}